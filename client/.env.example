# ShopSphere AI — Client Environment Variables
# Copy this file to .env and fill in your values
# .env is gitignored and must NEVER be committed

# VITE_API_URL specifies the backend API base URL.
# In development, you can leave this empty (or point to the proxy).
# In production, set this to your deployed backend URL.
VITE_API_URL=http://localhost:5000/api

# VITE_STRIPE_PUBLIC_KEY is required for processing payments.
VITE_STRIPE_PUBLIC_KEY=your_stripe_public_key_here
