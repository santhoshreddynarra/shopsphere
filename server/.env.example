# ShopSphere AI — Server Environment Variables
# Copy this file to .env and fill in your values
# .env is gitignored and must NEVER be committed

PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ─── MongoDB ───────────────────────────────────────────────────────────────────
# Option A — MongoDB Atlas (recommended for cloud/team dev):
#   1. Create a free cluster at https://cloud.mongodb.com
#   2. Create a database user under Security → Database Access
#   3. Whitelist your IP under Security → Network Access (0.0.0.0/0 for dev)
#   4. Click Connect → Drivers → copy the SRV connection string
#   5. Replace <username>, <password>, <cluster> below
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/shopsphere?retryWrites=true&w=majority&appName=ShopSphere

# Option B — Local MongoDB (requires mongod installed and running):
MONGO_URI=mongodb://127.0.0.1:27017/shopsphere

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Use a long random string in production — e.g.: openssl rand -hex 64
JWT_SECRET=replace_this_with_a_long_random_secret_in_production

